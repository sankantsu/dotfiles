#!/usr/bin/env bash
set -euo pipefail

echo "==> Bootstrap: setting up mise environment"

# Configure bashrc to source scripts in ~/.config/profile.d
BASHRC="$HOME/.bashrc"
MARKER="# >>> sankantsu/dotfiles: profile.d >>>"
if grep -qF "$MARKER" "$BASHRC"; then
    echo "==> profile.d sourcing already configured in $BASHRC, skipping"
else
    echo "==> Configuring profile.d sourcing in $BASHRC"
    cat >> "$BASHRC" <<'EOF'

# >>> sankantsu/dotfiles: profile.d >>>
if [ -d "$HOME/.config/profile.d" ]; then
    for f in "$HOME/.config/profile.d"/*.sh; do
        [ -f "$f" ] && . "$f"
    done
fi
# <<< sankantsu/dotfiles: profile.d <<<
EOF
fi

# Install mise if missing
MISE_BIN="$HOME/.local/bin/mise"
if [ -x "$MISE_BIN" ]; then
    echo "==> mise already installed at $MISE_BIN, skipping"
else
    echo "==> Installing mise"
    curl https://mise.run | sh
    echo "==> mise installed"
fi

# Activate mise
eval "$(~/.local/bin/mise activate bash)"

# Install tools declared in mise config
echo "==> Running: mise install"
mise install

# Run full environment setup task
echo "==> Running: mise run setup"
mise run setup

echo "==> Bootstrap complete!"
echo ""
echo "Run the following to apply shell changes to your current session:"
echo "source ~/.bashrc"
