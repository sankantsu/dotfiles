#!/usr/bin/env bash
set -euo pipefail

echo "==> Bootstrap: setting up mise environment"

# Install mise if missing
MISE_BIN="$HOME/.local/bin/mise"
if [ -x "$MISE_BIN" ]; then
    echo "==> mise already installed at $MISE_BIN, skipping"
else
    echo "==> Installing mise"
    curl https://mise.run | sh
    echo "==> mise installed"
fi

# Activate mise
eval "$(~/.local/bin/mise activate bash)"

# Install tools declared in mise config
echo "==> Running: mise install"
mise install

# Run full environment setup task
echo "==> Running: mise run setup"
mise run setup

echo "==> Bootstrap complete!"
